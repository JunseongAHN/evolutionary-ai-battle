{
  "name": "evolutionary-ai-battle",
  "version": "1.0.0",
  "description": "A co-player behavior evaluation harness built on an evolutionary battle simulation.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timjrobinson/evolutionary-ai-battle.git"
  },
  "main": "dist/app/index.js",
  "scripts": {
    "start": "npm run compile-browser && node server.js",
    "build": "npm run compile-browser && npm run compile-node",
    "test": "npm run compile-node && node --test dist/engine/agents/tests/botPolicy.test.js dist/engine/simulation/tests/combatState.test.js dist/engine/simulation/tests/battlegroundProjectiles.test.js dist/engine/traces/tests/trajectoryReplay.test.js dist/engine/traces/tests/trajectorySerialization.test.js dist/engine/traces/tests/trajectoryValidation.test.js dist/engine/policies/linearIntent/tests/linearIntent.test.js dist/evaluation/metrics/tests/playerMetrics.test.js dist/evaluation/metrics/tests/cpcMetrics.test.js dist/evaluation/tests/evaluateTrajectory.test.js dist/features/BattleEnvironment/scenarioInspection/tests/scenarioGt.test.js dist/features/BattleEnvironment/scenarioInspection/tests/actionAlignment.test.js dist/features/BattleEnvironment/scenarioInspection/tests/metricDirection.test.js",
    "typecheck": "tsc --noEmit",
    "compile-browser": "npx webpack --mode production",
    "compile-node": "tsc",
    "train-linear-intent-v0.2": "node experiment/training/train_linear_intent_v0_2.js",
    "train": "npm run compile-node && node dist/engine/evolution/coordinator.js"
  },
  "author": "Tim Robinson <tim@timjrobinson.com>",
  "license": "MIT",
  "keywords": [
    "NEAT",
    "neural network",
    "evolutionary neural network",
    "ai battle"
  ],
  "devDependencies": {
    "@babel/cli": "^7.8.4",
    "@babel/core": "^7.9.0",
    "@babel/preset-env": "^7.9.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ts-loader": "^9.6.0",
    "typescript": "^6.0.3",
    "webpack": "^5.76.0",
    "webpack-cli": "^5.0.1"
  },
  "dependencies": {
    "async": "^2.6.3",
    "debug": "^4.3.1",
    "koa": "^2.11.0",
    "koa-json": "^2.0.2",
    "koa-router": "^7.4.0",
    "koa-static": "^5.0.0",
    "open": "^7.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^3.4.0"
  }
}
